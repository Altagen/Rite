{
  "name": "rite",
  "version": "0.1.1",
  "private": true,
  "description": "Rust & TypeScript Interface for Terminal Environment",
  "repository": "https://github.com/Altagen/Rite",
  "license": "MIT OR Apache-2.0",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "scripts": {
    "dev": "pnpm --filter desktop dev",
    "build": "pnpm --filter desktop build",
    "lint": "pnpm -r lint",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "typecheck": "pnpm -r typecheck",
    "prepare": "husky"
  },
  "pnpm": {
    "overrides": {
      "minimatch@3": "3.1.4",
      "minimatch@9": "9.0.7",
      "rollup": "4.59.0",
      "glob": "10.5.0",
      "js-yaml": "4.1.1"
    }
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@types/node": "^22.10.2",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "typescript": "^5.7.2"
  }
}
